<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'My lists — BookApp' }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <h1 style="font-size: 28px; margin-bottom: 20px;">my lists</h1>

    <div style="background: white; border: 1px solid var(--border); border-radius: 10px; padding: 18px; margin-bottom: 24px;">
      <h2 style="font-size: 16px; margin-bottom: 14px;">create a new list</h2>
      <form action="/lists" method="post">
        <div class="form-group">
          <label>list name</label>
          <input type="text" name="name" required placeholder="e.g. summer reads" />
        </div>
        <div class="form-group">
          <label>description (optional)</label>
          <input type="text" name="description" placeholder="what is this list about?" />
        </div>
        <button type="submit" class="btn-primary">create list</button>
      </form>
    </div>

    <% if (lists.length === 0) { %>
      <div class="empty-state">
  <p>📚 no lists yet!</p>
  <p style="color: var(--muted); font-size: 0.9rem;">create your first list above — summer reads, favourites, whatever you like.</p>
</div>
    <% } else { %>
      <% lists.forEach(l => { %>
        <div style="background: white; border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <a href="/list/<%= l.List_ID %>" style="font-family: Fraunces, serif; font-size: 18px; color: var(--ink); font-weight: 500;">
              <%= l.List_Name %>
            </a>
            <% if (l.Description) { %>
              <div style="font-size: 13px; color: var(--ink-soft); margin-top: 2px;"><%= l.Description %></div>
            <% } %>
            <div style="font-size: 12px; color: var(--muted); margin-top: 4px;">
              <%= l.book_count %> book<%= l.book_count == 1 ? '' : 's' %>
            </div>
          </div>
          <form action="/lists/<%= l.List_ID %>/delete" method="post" style="margin: 0;">
            <button type="submit" class="btn-link" style="color: var(--danger); font-size: 13px;">delete</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>